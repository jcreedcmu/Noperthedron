/-- The rational table: every entry is its integer numerator over `10¹⁶`
(definitional, so the integer-core checkers can read `sqrtDvCurriedN`
directly). -/
def sqrtDvCurried (ℓa : Fin 2) (ia : Fin 3) (ka : Fin 15)
    (ℓb : Fin 2) (ib : Fin 3) (kb : Fin 15) : ℚ :=
  (sqrtDvCurriedN ℓa ia ka ℓb ib kb : ℚ) / 10 ^ 16

private lemma sqrtDvCurried_eq_0_0 : ∀ (k : Fin 15) (b : VertexIndex),
    sqrtDvCurried 0 0 k b.ℓ b.i b.k
      = RationalApprox.sqrtApprox16.upper_sqrt.norm
          (pythonVertexA ⟨k, 0, 0⟩ - pythonVertexA b) := by
  decide +kernel

private lemma sqrtDvCurried_eq_0_1 : ∀ (k : Fin 15) (b : VertexIndex),
    sqrtDvCurried 0 1 k b.ℓ b.i b.k
      = RationalApprox.sqrtApprox16.upper_sqrt.norm
