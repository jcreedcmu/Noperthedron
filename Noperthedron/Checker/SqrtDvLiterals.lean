    sqrtDvCurried 0 0 k b.ℓ b.i b.k
      = RationalApprox.sqrtApprox16.upper_sqrt.norm
          (pythonVertexA ⟨k, 0, 0⟩ - pythonVertexA b) := by
  decide +kernel

